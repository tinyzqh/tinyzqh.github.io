---
import { getCollection } from 'astro:content';

const news = (await getCollection('news')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const fmt = (iso: string) => {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
};
---

<section class="container-wide py-24">
  <p class="text-xs uppercase tracking-[0.22em] text-muted">News & milestones</p>
  <h2 class="mt-3 text-display-lg font-semibold tracking-tight">
    Selected <span class="font-serif italic text-fg/85">moments</span>.
  </h2>

  <ol class="relative mt-12 ml-3 border-l border-border/70">
    {news.map((n) => (
      <li class="pl-8 pb-8 last:pb-0 group">
        <span class="absolute -left-[7px] mt-1.5 grid place-items-center h-3.5 w-3.5 rounded-full bg-bg ring-2 ring-accent/40 transition group-hover:ring-accent group-hover:bg-accent/30"></span>
        <p class="text-xs uppercase tracking-[0.18em] text-muted">{fmt(n.data.date)}</p>
        <p class="mt-1 text-fg/95 leading-relaxed">
          {n.data.href ? (
            <a href={n.data.href} class="hover:text-accent transition">{n.data.title}</a>
          ) : (
            n.data.title
          )}
        </p>
      </li>
    ))}
  </ol>
</section>
