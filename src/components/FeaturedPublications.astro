---
import { getCollection } from 'astro:content';
import PublicationCard from '~/components/PublicationCard.astro';

const all = await getCollection('publications');
const featured = all
  .filter((p) => p.data.selected)
  .sort((a, b) => b.data.order - a.data.order);
---

<section class="container-wide py-24">
  <div class="flex items-end justify-between flex-wrap gap-4 mb-12">
    <div>
      <p class="text-xs uppercase tracking-[0.22em] text-muted">Selected publications</p>
      <h2 class="mt-3 text-display-lg font-semibold tracking-tight max-w-[24ch]">
        Recent work I'm <span class="font-serif italic text-fg/85">most proud of.</span>
      </h2>
    </div>
    <a href="/publications" class="text-sm text-muted hover:text-accent transition inline-flex items-center gap-1">
      All publications
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {featured.map((p) => <PublicationCard pub={p} />)}
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.spotlight').forEach((el) => {
    el.addEventListener('mousemove', (e) => {
      const rect = el.getBoundingClientRect();
      el.style.setProperty('--mx', `${e.clientX - rect.left}px`);
      el.style.setProperty('--my', `${e.clientY - rect.top}px`);
    });
  });
</script>
