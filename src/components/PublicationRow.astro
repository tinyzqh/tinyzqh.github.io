---
import type { CollectionEntry } from 'astro:content';

interface Props {
  pub: CollectionEntry<'publications'>;
  index?: number;
}

const { pub, index } = Astro.props;
const { data, id } = pub;
---

<article class="group relative grid grid-cols-1 sm:grid-cols-[140px_1fr] md:grid-cols-[180px_1fr] gap-5 sm:gap-6 py-7 first:pt-0 border-t border-border/40 first:border-t-0">
  <a href={`/publications/${id}/`} class="block relative overflow-hidden rounded-xl bg-bg-elevated/50 ring-1 ring-border aspect-[16/10] sm:aspect-square">
    {data.image ? (
      <img
        src={data.image}
        alt=""
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.05]"
      />
    ) : (
      <div class="h-full w-full grid place-items-center bg-gradient-to-br from-accent/10 to-cyan-500/5">
        <span class="text-xs uppercase tracking-[0.2em] text-muted">{data.status === 'preprint' ? 'Preprint' : data.venueShort ?? 'Paper'}</span>
      </div>
    )}
    <div class="absolute inset-0 ring-1 ring-inset ring-white/5 rounded-xl pointer-events-none"></div>
  </a>

  <div class="min-w-0 flex flex-col">
    <div class="flex flex-wrap items-center gap-2 mb-2">
      <span class="pill bg-bg-elevated/70 backdrop-blur">
        <em class="not-italic text-fg/90 font-medium">{data.venueShort ?? data.venue}</em>
        <span class="text-muted/60">·</span>
        <span class="tabular-nums">{data.year}</span>
      </span>
      {data.quartile && (
        <span class="pill bg-accent/10 ring-accent/30 text-accent">
          {data.quartile}{data.impactFactor ? ` · IF ${data.impactFactor}` : ''}
        </span>
      )}
      {data.status === 'accepted' && <span class="pill text-amber-300 ring-amber-400/30">Accepted</span>}
      {data.status === 'preprint' && <span class="pill">Preprint</span>}
      {data.tags.slice(0, 2).map((t) => (
        <span class="pill text-muted/80 hidden md:inline-flex">{t}</span>
      ))}
    </div>

    <h3 class="text-lg sm:text-xl font-semibold tracking-tight leading-snug">
      <a href={`/publications/${id}/`} class="text-fg group-hover:text-accent transition">
        {data.title}
      </a>
    </h3>

    <p class="mt-2 text-sm text-muted leading-relaxed">
      {data.authors.map((a, i) => (
        <>
          <span class={a.me ? 'text-fg' : ''}>{a.name}</span>{a.corresponding && <sup class="text-accent">*</sup>}{i < data.authors.length - 1 ? ', ' : ''}
        </>
      ))}
    </p>

    {data.abstract && (
      <p class="mt-3 text-sm text-muted/90 leading-relaxed line-clamp-2 max-w-prose">
        {data.abstract}
      </p>
    )}

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs">
      {data.paperUrl && (
        <a href={data.paperUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-fg/80 hover:text-accent transition">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Paper
        </a>
      )}
      {data.arxiv && (
        <a href={`https://arxiv.org/abs/${data.arxiv}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-fg/80 hover:text-accent transition">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
          arXiv
        </a>
      )}
      {data.code && (
        <a href={data.code} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-fg/80 hover:text-accent transition">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Code
        </a>
      )}
      {data.pdf && (
        <a href={data.pdf} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-fg/80 hover:text-accent transition">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          PDF
        </a>
      )}
      <a href={`/publications/${id}/`} class="ml-auto inline-flex items-center gap-1 text-muted hover:text-accent transition">
        Details
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</article>
