---
import type { CollectionEntry } from 'astro:content';

interface Props {
  pub: CollectionEntry<'publications'>;
  variant?: 'compact' | 'full';
}

const { pub, variant = 'compact' } = Astro.props;
const { data, id } = pub;
const meAuthors = data.authors;
const venuePill = `${data.venueShort ?? data.venue}${data.year ? ` · ${data.year}` : ''}`;
---

<a
  href={`/publications/${id}/`}
  class="spotlight surface group flex flex-col overflow-hidden transition hover:-translate-y-0.5 hover:ring-accent/40"
>
  {data.image && (
    <div class="relative aspect-[16/10] overflow-hidden bg-bg-subtle">
      <img
        src={data.image}
        alt=""
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-bg-elevated/90 via-bg-elevated/10 to-transparent"></div>
      <div class="absolute top-3 left-3 flex flex-wrap gap-1.5">
        <span class="pill bg-bg/70 backdrop-blur">{venuePill}</span>
        {data.quartile && (
          <span class="pill bg-accent/15 ring-accent/30 text-accent">{data.quartile}{data.impactFactor ? ` · IF ${data.impactFactor}` : ''}</span>
        )}
      </div>
    </div>
  )}
  <div class="flex-1 p-5 flex flex-col">
    <h3 class="text-base font-semibold leading-snug tracking-tight text-fg line-clamp-3">
      {data.title}
    </h3>
    <p class="mt-2 text-xs text-muted leading-relaxed line-clamp-2">
      {meAuthors.map((a, i) => (
        <>
          <span class={a.me ? 'text-fg' : ''}>{a.name}</span>
          {a.corresponding && <sup class="text-accent">*</sup>}
          {i < meAuthors.length - 1 ? ', ' : ''}
        </>
      ))}
    </p>
    <div class="mt-auto pt-4 flex items-center justify-between">
      <span class="text-[11px] uppercase tracking-[0.18em] text-muted/80">
        {data.status === 'preprint' ? 'Preprint' : data.status === 'accepted' ? 'Accepted' : 'Published'}
      </span>
      <span class="text-muted group-hover:text-accent transition" aria-hidden="true">→</span>
    </div>
  </div>
</a>
