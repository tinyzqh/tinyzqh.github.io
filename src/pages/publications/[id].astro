---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import BibtexCopy from '~/components/BibtexCopy.tsx';

export async function getStaticPaths() {
  const pubs = await getCollection('publications');
  return pubs.map((pub) => ({ params: { id: pub.id }, props: { pub } }));
}

const { pub } = Astro.props;
const { data } = pub;
const { Content } = await render(pub);

const generatedBibtex =
  data.bibtex ??
  `@article{${pub.id.replace(/[^a-z0-9]/gi, '')},
  title   = {${data.title}},
  author  = {${data.authors.map((a) => a.name).join(' and ')}},
  journal = {${data.venue}},
  year    = {${data.year}}
}`;
---

<BaseLayout
  title={data.title}
  description={data.abstract ?? data.title}
  image={data.image ?? '/images/profile.jpg'}
  ogType="article"
>
  <article class="container-wide pt-20 pb-12 max-w-4xl">
    <p class="text-xs uppercase tracking-[0.22em] text-muted">
      <a href="/publications" class="hover:text-accent transition">Publications</a>
      <span class="mx-2 text-muted/40">/</span>
      <span>{data.year}</span>
    </p>

    <h1 class="mt-6 text-display-lg font-semibold tracking-tight">{data.title}</h1>

    <p class="mt-6 text-lg text-muted leading-relaxed">
      {data.authors.map((a, i) => (
        <>
          <span class={a.me ? 'text-fg font-medium' : ''}>{a.name}</span>
          {a.corresponding && <sup class="text-accent">*</sup>}
          {i < data.authors.length - 1 ? <span class="text-muted/60">,&nbsp;</span> : null}
        </>
      ))}
    </p>

    <p class="mt-3 flex flex-wrap items-center gap-2 text-sm">
      <span class="pill"><em class="not-italic font-medium text-fg">{data.venue}</em> · {data.year}</span>
      {data.quartile && (
        <span class="pill bg-accent/15 ring-accent/30 text-accent">
          {data.quartile}{data.impactFactor ? ` · IF ${data.impactFactor}` : ''}
        </span>
      )}
      {data.status === 'accepted' && <span class="pill text-amber-300 ring-amber-400/30">Accepted</span>}
      {data.status === 'preprint' && <span class="pill">Preprint</span>}
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      {data.paperUrl && <a href={data.paperUrl} target="_blank" rel="noopener" class="btn-primary">Read paper</a>}
      {data.arxiv && <a href={`https://arxiv.org/abs/${data.arxiv}`} target="_blank" rel="noopener" class="btn-ghost">arXiv {data.arxiv}</a>}
      {data.code && <a href={data.code} target="_blank" rel="noopener" class="btn-ghost">Code</a>}
      {data.pdf && <a href={data.pdf} target="_blank" rel="noopener" class="btn-ghost">PDF</a>}
      <BibtexCopy bibtex={generatedBibtex} client:load />
    </div>
  </article>

  {data.image && (
    <div class="container-wide max-w-4xl">
      <div class="surface overflow-hidden">
        <img src={data.image} alt="" class="w-full object-cover" loading="lazy" />
      </div>
    </div>
  )}

  <article class="container-wide max-w-prose py-16 prose-fg">
    {data.abstract && (
      <>
        <h2 class="text-xs uppercase tracking-[0.22em] text-muted mb-3">Abstract</h2>
        <p class="text-lg text-fg/90 leading-relaxed">{data.abstract}</p>
      </>
    )}
    <div class="mt-10 text-fg/85 leading-relaxed">
      <Content />
    </div>
    {data.note && <p class="mt-8 text-sm text-muted italic">{data.note}</p>}
  </article>

  <div class="container-wide max-w-prose pb-20">
    <details class="surface group p-5">
      <summary class="flex items-center justify-between cursor-pointer text-sm font-medium text-fg/90 list-none">
        BibTeX
        <span class="text-muted transition group-open:rotate-180" aria-hidden="true">⌃</span>
      </summary>
      <pre class="mt-4 overflow-x-auto text-xs font-mono text-fg/80 bg-bg-subtle/60 p-4 rounded-lg whitespace-pre">{generatedBibtex}</pre>
    </details>
  </div>
</BaseLayout>
